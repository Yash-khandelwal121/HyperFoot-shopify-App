{
  "version": 2,
  "buildCommand": "npm run setup && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "build",
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
